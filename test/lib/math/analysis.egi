--
-- Originally auto-generated by egison-translator; modernized for the
-- typed CAS (declare symbol; expectations follow the current normal
-- forms: the Pythagorean auto rule rewrites cos^2 to 1 - sin^2, and
-- casRewriteExp merges exp products and powers).
--
-- Two original cases are deliberately absent:
--   * "d/d - case 2" (d/d (a ^ (x ^ 2)) x): a symbolic-base power
--     evaluates to the opaque applied form '^ a (x^2), which the
--     derivative engine treats as constant and differentiates to 0.
--     Needs a derivative rule for u^v before it can be asserted.
--   * the function-symbol cases (multivariateTaylorExpansion of f x y,
--     d/d f y = userRefs f [y]): the typed integration of function
--     symbols is undecided (design/function-symbol.md); d/d yields the
--     positional index f|2 while userRefs yields the named f|(y).
--

declare symbol x, z

assertEqual "d/d - case 1" (d/d (x ^ 2) x) (2 * x)

assertEqual "d/d - case 3" (d/d (cos x * sin x) x) (1 - 2 * sin x ^ 2)

assertEqual
  "d/d - case 4"
  (d/d (sigmoid z) z)
  (exp (- z) / (1 + 2 * exp (- z) + exp (-2 * z)))

assertEqual "d/d - case 5" (d/d (d/d (log x) x) x) ((-1) / x ^ 2)

assertEqual
  "taylor-expansion - case 1"
  (take 4 (taylorExpansion (e ^ (i * x)) x 0))
  [1, i * x, -1 * x ^ 2 / 2, -1 * i * x ^ 3 / 6]
